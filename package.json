{
  "private": true,
  "name": "jonstuebe.com",
  "description": "Personal site for Jon Stuebe",
  "license": "",
  "scripts": {
    "build": "npm run css:build && npm run cache:content && remix build",
    "dev": "node -r dotenv/config node_modules/.bin/remix dev",
    "postinstall": "remix setup node && patch-package",
    "cache:content": "node -r esbuild-register cache.ts",
    "css:dev": "tailwindcss -i ./app/styles/styles.css -o ./app/styles/tailwind.css --config ./config/tailwind.js --watch",
    "css:build": "tailwindcss -i ./app/styles/styles.css -o ./app/styles/tailwind.css --config ./config/tailwind.js --minify"
  },
  "dependencies": {
    "@headlessui/react": "^1.4.2",
    "@remix-run/react": "^1.1.1",
    "@remix-run/serve": "^1.1.1",
    "@remix-run/vercel": "^1.1.1",
    "@tailwindcss/typography": "^0.5.0",
    "chrome-aws-lambda": "^10.1.0",
    "date-fns": "^2.27.0",
    "dotenv": "^10.0.0",
    "esbuild": "^0.14.5",
    "esbuild-register": "^3.2.1",
    "gray-matter": "^4.0.3",
    "inter-ui": "^3.19.3",
    "patch-package": "^6.4.7",
    "puppeteer-serverless": "^2.0.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "reading-time": "^1.5.0",
    "redis": "^4.0.1",
    "remark": "^14.0.2",
    "remark-autolink-headings": "^7.0.1",
    "remark-external-links": "^9.0.1",
    "remark-html": "^15.0.1",
    "remark-prism": "^1.3.6",
    "remark-slug": "^7.0.1",
    "remix": "^1.1.1",
    "tailwindcss": "^3.0.7",
    "tailwindcss-scrollbar": "^0.1.0",
    "tedis": "^0.1.12",
    "tiny-invariant": "^1.2.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.1.1",
    "@types/react": "^17.0.24",
    "@types/react-dom": "^17.0.9",
    "@types/remark-prism": "^1.3.0",
    "typescript": "^4.1.2"
  },
  "engines": {
    "node": ">=14"
  },
  "sideEffects": false
}
